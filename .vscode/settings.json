{
  // Routeplane workspace LSP wiring — applies to VS Code (Remote-WSL or native),
  // Antigravity, and any Code-OSS-based IDE that reads workspace .vscode/.
  // Portable across machines/usernames: rust-analyzer resolves from PATH, and the
  // Terraform / TOML extensions manage their own bundled language servers (no
  // machine-specific binary paths). Honored when the editor runs INSIDE WSL.

  // ---- Rust (the data plane) -------------------------------------------------
  // The Cargo workspace lives in routeplane/, not at the meta-repo root, so point
  // rust-analyzer at its manifest explicitly (otherwise it finds no Cargo.toml here).
  "rust-analyzer.linkedProjects": ["routeplane/Cargo.toml"],
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.procMacro.enable": true,

  // ---- Terraform / HCL -------------------------------------------------------
  // Let the hashicorp.terraform extension manage its own terraform-ls — portable,
  // no machine-specific path. To force the harness-installed CLI instead, set
  // terraform.languageServer.path to an absolute path in your *User* settings.
  "terraform.languageServer.enable": true,

  // ---- YAML (GitHub Actions workflows + general) -----------------------------
  "yaml.schemaStore.enable": true,
  "yaml.validate": true,
  "yaml.format.enable": true,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      "**/.github/workflows/*.yml",
      "**/.github/workflows/*.yaml"
    ],
    "https://json.schemastore.org/github-action.json": [
      "**/action.yml",
      "**/action.yaml"
    ]
  },

  // ---- TOML (Cargo manifests) ------------------------------------------------
  // Even Better TOML ships its own taplo; no bin override keeps this portable.
  // Override evenBetterToml.taplo.bin in your *User* settings for the harness CLI.
  "evenBetterToml.formatter.alignEntries": false,

  // ---- File associations -----------------------------------------------------
  "files.associations": {
    "*.tf": "terraform",
    "*.tfvars": "terraform",
    "Cargo.lock": "toml",
    "keys.json": "jsonc"
  }
}
